# Copy to .env for local test-only deployment. Never reuse these roles on mainnet.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://your-production-base-rpc-provider.example
DEPLOYER_PRIVATE_KEY=replace_with_environment_specific_private_key
ORACLE_ADDRESS=0xreplace_with_environment_specific_oracle_address
OWNER_ADDRESS=0xreplace_with_multisig_or_test_admin_address
MAX_TOTAL_PRINCIPAL_ETH=0.5
BASESCAN_API_KEY=replace_with_verification_api_key
