# GitHub OAuth App — create at github.com/settings/applications/new
# Callback URL: http://localhost:3000/api/auth/callback/github (dev)
#               https://basecred.nachdakwale.workers.dev/api/auth/callback/github (prod)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Oracle wallet private key (0x-prefixed) — this wallet calls setScore on-chain
# Must have Base Sepolia ETH for gas. Fund from: https://faucet.base.org/
ORACLE_PRIVATE_KEY=0x

# Deployed contract address (set after running: cd contracts && npm run deploy:sepolia)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x

NEXTAUTH_URL=http://localhost:3000
