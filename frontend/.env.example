# Build-time public values. Provide an independent set for each deployment artifact.
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_CONTRACT_ADDRESS=0xreplace_with_fresh_environment_contract
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.basescan.org
NEXT_PUBLIC_NETWORK_NAME=Base Sepolia Testnet
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# Runtime non-public values. Store deployed values with `wrangler secret put --env <env>`.
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=replace_locally_only
AUTH_GITHUB_ID=replace_locally_only
AUTH_GITHUB_SECRET=replace_locally_only
GITHUB_API_TOKEN=replace_locally_only
ORACLE_PRIVATE_KEY=replace_locally_only
RPC_URL=https://sepolia.base.org
