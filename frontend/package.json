{
  "name": "basecred",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest run",
    "build:testnet": "dotenv -e .env.testnet.local -- node scripts/build-worker.mjs testnet",
    "build:mainnet": "dotenv -e .env.mainnet.local -- node scripts/build-worker.mjs mainnet",
    "deploy:testnet": "npm run build:testnet && wrangler deploy --env testnet",
    "deploy:mainnet": "npm run build:mainnet && wrangler deploy --env mainnet"
  },
  "dependencies": {
    "@tanstack/react-query": "^5",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "react": "^19",
    "react-dom": "^19",
    "viem": "^2",
    "wagmi": "^2"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^8",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "uuid": "^11.1.1",
    "ws": "^8.21.0"
  }
}
